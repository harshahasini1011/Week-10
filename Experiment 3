#include <stdio.h>
#include <stdlib.h>

int main() {
    int *m, *c;
    int n = 5;

    m = (int*)malloc(n * sizeof(int));
    printf("malloc values:\n");
    for(int i = 0; i < n; i++) {
        m[i] = i + 1;
        printf("%d ", m[i]);
    }

    c = (int*)calloc(n, sizeof(int));
    printf("\ncalloc values:\n");
    for(int i = 0; i < n; i++) {
        printf("%d ", c[i]); // default 0
    }

    return 0;
}
