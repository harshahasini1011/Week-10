#include <stdio.h>
#include <stdlib.h>

int main() {
    int *p;
    int n = 3;

    p = (int*)malloc(n * sizeof(int));

    printf("Enter 3 values:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &p[i]);
    }

    p = (int*)realloc(p, 5 * sizeof(int));

    printf("Enter 2 more values:\n");
    for(int i = 3; i < 5; i++) {
        scanf("%d", &p[i]);
    }

    printf("Final array:\n");
    for(int i = 0; i < 5; i++) {
        printf("%d ", p[i]);
    }

    free(p); 

    return 0;
}
